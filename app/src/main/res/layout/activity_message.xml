<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:orientation="vertical"
    android:backgroundTint="@color/white"
    android:padding="10dp">

    <RelativeLayout
        android:id="@+id/toolRlLay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <ImageView
            android:id="@+id/imgBack"
            android:layout_width="@dimen/_20sdp"
            android:layout_height="@dimen/_20sdp"
            android:layout_centerVertical="true"
            android:layout_marginStart="@dimen/_10sdp"
            android:src="@drawable/back" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/_10sdp"
            android:layout_toEndOf="@+id/imgBack"
            android:orientation="horizontal"
            android:padding="10dp">

            <LinearLayout
                android:id="@+id/nameLay"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/circle_background">

                <TextView
                    android:id="@+id/firstName"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="center_vertical"
                    android:gravity="center"
                    android:text="J"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/_10sdp"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/contact_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Contact Name"
                    android:textColor="@color/black"
                    android:textStyle="bold"
                    android:textSize="16sp" />
                <TextView
                    android:id="@+id/phoneNumber"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textColor="@android:color/darker_gray" />
            </LinearLayout>


        </LinearLayout>

        <ImageView
            android:id="@+id/imgSearch"
            android:layout_width="@dimen/_20sdp"
            android:layout_height="@dimen/_25sdp"
            android:layout_centerVertical="true"
            android:layout_gravity="center"
            android:layout_marginEnd="@dimen/_15sdp"
            android:layout_toStartOf="@+id/imgThreeDots"
            android:src="@drawable/search" />

        <ImageView
            android:id="@+id/imgThreeDots"
            android:layout_width="@dimen/_20sdp"
            android:layout_height="@dimen/_20sdp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:layout_gravity="center"
            android:layout_marginEnd="@dimen/_15sdp"
            android:src="@drawable/three_dots" />


    </RelativeLayout>

    <View
        android:id="@+id/view"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_below="@+id/toolRlLay"
        android:background="@color/translucent" />


    <androidx.recyclerview.widget.RecyclerView
        android:layout_below="@+id/toolRlLay"
        android:id="@+id/rcvMassage"
        android:layout_width="match_parent"
        android:layout_above="@+id/laySendMassage"
        android:layout_height="match_parent"/>


    <RelativeLayout
        android:id="@+id/laySendMassage"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/_40sdp"
        android:layout_alignParentBottom="true"
        android:background="@drawable/bg_gray_color"
        android:orientation="horizontal">

      <ImageView
          android:id="@+id/imgCalender"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_centerVertical="true"
          android:layout_marginLeft="@dimen/_10sdp"
          android:src="@drawable/icon_calender"/>
        <EditText
            android:id="@+id/etEditText"
            android:layout_width="@dimen/_150sdp"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@+id/imgCalender"
            android:layout_centerVertical="true"
            android:hint="write a massages..."
            android:layout_marginStart="@dimen/_5sdp"
            android:background="@null" />
        <ImageView
            android:id="@+id/imgAttachment"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/_23sdp"
            android:layout_centerVertical="true"
            android:src="@drawable/icon_attachmnet"
            android:layout_toEndOf="@+id/etEditText"/>

        <LinearLayout
            android:id="@+id/laySend"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:gravity="center"
            android:layout_marginRight="@dimen/_10sdp"
            android:layout_centerVertical="true"
            android:background="@drawable/bg_send_cp">

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/img_send"/>

        </LinearLayout>

    </RelativeLayout>

</RelativeLayout>
