<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:fitsSystemWindows="true"
    android:orientation="vertical"
    android:backgroundTint="@color/white"
    android:padding="10dp">

    <RelativeLayout
        android:id="@+id/toolRlLay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <ImageView
            android:id="@+id/imgBack"
            android:layout_width="@dimen/_20sdp"
            android:layout_height="@dimen/_20sdp"
            android:layout_centerVertical="true"
            android:layout_marginStart="@dimen/_10sdp"
            android:src="@drawable/back" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/_10sdp"
            android:layout_toEndOf="@+id/imgBack"
            android:orientation="horizontal"
            android:padding="10dp">

            <LinearLayout
                android:id="@+id/nameLay"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/circle_background">

                <TextView
                    android:id="@+id/firstName"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="center_vertical"
                    android:gravity="center"
                    android:text="J"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/_10sdp"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/contact_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Contact Name"
                    android:textColor="@color/black"
                    android:textStyle="bold"
                    android:textSize="16sp" />
                <TextView
                    android:id="@+id/phoneNumber"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textColor="@android:color/darker_gray" />
            </LinearLayout>


        </LinearLayout>

        <ImageView
            android:id="@+id/imgSearch"
            android:layout_width="@dimen/_20sdp"
            android:layout_height="@dimen/_25sdp"
            android:layout_centerVertical="true"
            android:layout_gravity="center"
            android:layout_marginEnd="@dimen/_15sdp"
            android:layout_toStartOf="@+id/imgThreeDots"
            android:src="@drawable/search" />

        <ImageView
            android:id="@+id/imgThreeDots"
            android:layout_width="@dimen/_20sdp"
            android:layout_height="@dimen/_20sdp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:layout_gravity="center"
            android:layout_marginEnd="@dimen/_15sdp"
            android:src="@drawable/three_dots" />


    </RelativeLayout>

    <LinearLayout
        android:id="@+id/llSearch"
        android:layout_width="match_parent"
        android:layout_height="@dimen/_55sdp"
        android:layout_below="@id/toolRlLay"
        android:gravity="center"
        android:orientation="horizontal"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/ll3"
            android:layout_width="@dimen/_250sdp"
            android:layout_height="@dimen/_37sdp"
            android:background="@drawable/shape"
            android:visibility="visible">

            <ImageView
                android:id="@+id/icSearch"
                android:layout_width="@dimen/_20sdp"
                android:layout_height="@dimen/_11sdp"
                android:layout_gravity="center"
                android:layout_marginStart="@dimen/_10ssp"
                android:src="@drawable/search"
                app:tint="@color/translucent" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="@dimen/_30ssp"
                android:layout_gravity="center"
                android:layout_marginStart="@dimen/_10ssp"
                android:text="|"
                android:textColor="@color/translucent"
                android:textSize="@dimen/_20ssp" />

            <EditText
                android:id="@+id/searchText"
                android:layout_width="@dimen/_160sdp"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginStart="@dimen/_10ssp"
                android:background="@null"
                android:hint="Search..."
                android:imeOptions="actionDone"
                android:inputType="text"
                android:textColor="@color/black"
                android:textColorHint="@color/translucent"
                android:textSize="@dimen/_12ssp" />
        </LinearLayout>

        <ImageView
            android:id="@+id/imgMainClose"
            android:layout_width="@dimen/_20sdp"
            android:layout_height="@dimen/_20sdp"
            android:layout_gravity="center"
            android:layout_marginStart="@dimen/_10sdp"
            android:src="@drawable/close" />
    </LinearLayout>


    <View
        android:id="@+id/view"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_below="@+id/llSearch"
        android:background="@color/translucent" />


    <androidx.recyclerview.widget.RecyclerView
        android:layout_below="@+id/view"
        android:id="@+id/rcvMassage"
        android:layout_width="match_parent"
        android:layout_above="@+id/laySendMassage"
        android:layout_height="match_parent"/>


    <RelativeLayout
        android:id="@+id/laySendMassage"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/_40sdp"
        android:layout_alignParentBottom="true"
        android:background="@drawable/bg_gray_color"
        android:orientation="horizontal">

      <ImageView
          android:id="@+id/imgCalender"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_centerVertical="true"
          android:layout_marginLeft="@dimen/_10sdp"
          android:src="@drawable/icon_calender"/>
        <EditText
            android:id="@+id/etEditText"
            android:layout_width="@dimen/_150sdp"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@+id/imgCalender"
            android:layout_centerVertical="true"
            android:hint="write a massages..."
            android:layout_marginStart="@dimen/_5sdp"
            android:background="@null" />
        <ImageView
            android:id="@+id/imgAttachment"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/_23sdp"
            android:layout_centerVertical="true"
            android:src="@drawable/icon_attachmnet"
            android:layout_toEndOf="@+id/etEditText"/>

        <LinearLayout
            android:id="@+id/laySend"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:gravity="center"
            android:layout_marginRight="@dimen/_10sdp"
            android:layout_centerVertical="true"
            android:background="@drawable/bg_send_cp">

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/img_send"/>

        </LinearLayout>

    </RelativeLayout>

    <LinearLayout
        android:id="@+id/llNoData"
        android:layout_width="match_parent"
        android:layout_height="@dimen/_50sdp"
        android:layout_centerVertical="true"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="@dimen/_10ssp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/_10sdp"
            android:text="No Data Found"
            android:textColor="@color/black"
            android:textSize="@dimen/_20ssp"
            android:textStyle="bold"
            android:visibility="visible" />
    </LinearLayout>


</RelativeLayout>
